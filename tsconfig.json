{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },
  "include": ["contracts/**/*.ts", "hardhat.config.ts"],
  "exclude": ["node_modules", "web", "server", "indexer", "test"]
}
