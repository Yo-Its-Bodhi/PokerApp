# Production Environment Variables
# Replace these with your actual values when deploying

# Network Configuration
VITE_NETWORK=mainnet
VITE_CHAIN_ID=9008
VITE_RPC_URL=https://rpc-nodes.shidoscan.com
VITE_WS_URL=wss://ws-nodes.shidoscan.com

# Smart Contract Addresses (Deploy contracts first, then update these)
VITE_TABLE_FACTORY_ADDRESS=
VITE_TABLE_ESCROW_ADDRESS=
VITE_RAKE_VAULT_ADDRESS=

# Server Configuration (For multiplayer mode)
VITE_SERVER_URL=
VITE_SERVER_WS_URL=

# Feature Flags
VITE_DEMO_MODE=true
VITE_MULTIPLAYER_ENABLED=false
